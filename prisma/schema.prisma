generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// Per-user settings (Firebase UID as id)
model UserSettings {
  id           String  @id @map("_id")
  /// AES-256-GCM envelope (base64): iv + authTag + ciphertext
  openaiKeyEnc String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Debate {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  /// Firebase Auth UID — debates are scoped per user on the API
  userId    String
  topic     String
  /// User's raw input when it differed from the neutral `topic`
  originalTopic String?
  status    DebateStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  turns     Turn[]
  /// Stored when debate ends: { "bullets": string[], "closingRemark"?: string }
  debateSummary Json?
  /// Listed on `/community` when true (ended debates only).
  isPublic Boolean @default(false)

  @@index([userId])
  @@index([isPublic, status])
}

model Turn {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  debateId  String      @db.ObjectId
  debate    Debate      @relation(fields: [debateId], references: [id], onDelete: Cascade)
  role      SpeakerRole
  content   String
  sequence  Int
  createdAt DateTime    @default(now())

  @@index([debateId])
}

enum DebateStatus {
  ACTIVE
  ENDED
}

enum SpeakerRole {
  PRO
  CONTRA
  /// Human viewer chiming into the live debate (not an AI speaker)
  USER
}
